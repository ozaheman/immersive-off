# Google drive API oauth credentials from GCP cloud console
GOOGLE_DRIVE_OAUTH_CLIENT_ID = "<GOOGLE_DRIVE_OAUTH_CLIENT_ID>"
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET = "<GOOGLE_DRIVE_OAUTH_CLIENT_SECRET>"

# Enable Google Drive integration for file uploads/downloads in js/database.js
GOOGLE_DRIVE_ENABLED = "<GOOGLE_DRIVE_ENABLED>" #true/false

# OAuth scopes used by Google Identity Services token flow
GOOGLE_DRIVE_SCOPES = "<GOOGLE_DRIVE_SCOPES>"

# Root folder created in Google Drive. Sub-folders are auto-created as:
# <ROOT>/<source>/<jobNo>/<category>/<subCategory>
GOOGLE_DRIVE_ROOT_FOLDER = "<GOOGLE_DRIVE_ROOT_FOLDER>"

# If false, dataUrl content is not persisted locally after successful Drive upload.
# Turn true if you want offline previews from IndexedDB.
GOOGLE_DRIVE_STORE_LOCAL_CACHE = "<GOOGLE_DRIVE_STORE_LOCAL_CACHE>" #false

# Optional: used by hosting/runtime injection strategy
GOOGLE_DRIVE_REDIRECT_URI = "<GOOGLE_DRIVE_REDIRECT_URI>"

# Media Storage Configuration: Toggle between Google Drive and MongoDB base64 storage
# MEDIA_STORAGE_PROVIDER options: gdrive | mongodb
# - gdrive: Store files in Google Drive (requires GOOGLE_DRIVE_ENABLED=true)
# - mongodb: Store files as base64 in MongoDB/PostgreSQL (requires DB_PROVIDER=mongodb or postgresql)
MEDIA_STORAGE_PROVIDER = "gdrive"

# When MEDIA_STORAGE_PROVIDER=mongodb, store full file as base64 in database
# Set to true to store files in MongoDB/PostgreSQL instead of Google Drive
MONGODB_STORE_BASE64_FILES = "false"

# ------------------------------------------------------------------------------
# Persistent Database Provider Configuration
# DB_PROVIDER options: indexeddb | mongodb | postgresql
# - indexeddb: browser local storage only (current fallback)
# - mongodb: use server API backed by MongoDB Atlas
# - postgresql: use server API backed by PostgreSQL
# ------------------------------------------------------------------------------
DB_PROVIDER = "<DB_PROVIDER>"

# Frontend -> backend DB API base URL
DB_API_BASE_URL = "<DB_API_BASE_URL>"

# Node server settings
PORT = "<PORT>"

# MongoDB Atlas settings (required when DB_PROVIDER=mongodb)
MONGODB_URI = "mongodb+srv://<username>:<password>@<cluster_url>/?appName=<app_name>&retryWrites=true&w=majority"
MONGODB_DB_NAME = "<MONGODB_DB_NAME>"

# PostgreSQL settings (required when DB_PROVIDER=postgresql)
POSTGRES_URL = postgresql://<username>:<password>@<host>:5432/<database>
POSTGRES_SSL_MODE = require