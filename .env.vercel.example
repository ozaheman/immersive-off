# ========================================
# VERCEL DEPLOYMENT ENVIRONMENT VARIABLES
# ========================================

# Choose ONE database provider: indexeddb, mongodb, or postgresql
DB_PROVIDER=mongodb

# MongoDB Configuration (if using MongoDB)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=immersive_db

# PostgreSQL Configuration (if using PostgreSQL)
# POSTGRES_URL=postgresql://user:password@host:5432/immersive_db
# POSTGRES_SSL_MODE=require

# Server Configuration
PORT=3000
NODE_ENV=production
DB_API_BASE_URL=/api

# Google Drive Integration (Optional)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_ROOT_FOLDER=UrbanAxis Media
GOOGLE_DRIVE_STORE_LOCAL_CACHE=false
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.file
